{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "Whole Page",
  "version": "1.2.0",
  "description": "Right-click to reload the whole page or the element under cursor (bypassing cache).",
  "icons": {
      "48": "images/icon-48.png",
      "96": "images/icon-96.png",
      "128": "images/icon-128.png",
      "256": "images/icon-256.png",
      "512": "images/icon-512.png"
  },
  "background": {
      "scripts": [ "background.js" ],
      "type": "module"
  },
  "action": {
    "default_title": "Whole Page Settings",
    "default_popup": "settings.html",
    "default_icon": {
      "48": "images/icon-48.png",
      "96": "images/icon-96.png",
      "128": "images/icon-128.png"
    }
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": [
    "contextMenus",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
